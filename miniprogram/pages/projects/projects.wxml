<!-- 项目列表页 -->
<view class="container">
  <!-- 筛选标签 -->
  <scroll-view scroll-x class="tabs">
    <view class="tab {{filter==='all'?'active':''}}" bindtap="setFilter" data-filter="all">全部</view>
    <view class="tab {{filter==='pending'?'active':''}}" bindtap="setFilter" data-filter="pending">待评审</view>
    <view class="tab {{filter==='done'?'active':''}}" bindtap="setFilter" data-filter="done">已完成</view>
    <view wx:if="{{role==='expert'}}" class="tab {{filter==='returned'?'active':''}}" bindtap="setFilter" data-filter="returned">已退回</view>
  </scroll-view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="empty-state">
    <text style="font-size:80rpx">⏳</text>
    <text>加载中…</text>
  </view>

  <!-- 项目列表 -->
  <block wx:elif="{{filteredProjects.length > 0}}">
    <view class="card project-card" wx:for="{{filteredProjects}}" wx:key="_id"
          bindtap="goDetail" data-id="{{item._id}}" data-name="{{item.name}}" data-assignment-id="{{item.assignmentId}}">
      <view class="pc-header">
        <text class="pc-name">{{item.name}}</text>
        <view class="tag {{item.reviewStatusClass}}">{{item.reviewStatusLabel || item.reviewStatus}}</view>
      </view>
      <view class="pc-info">
        <text class="pc-institution" wx:if="{{item.institution}}">🏛 {{item.institution}}</text>
        <text class="pc-leader" wx:if="{{item.leader}}">👤 {{item.leader}}</text>
        <text class="pc-round" wx:if="{{item.roundName && role==='expert'}}">📅 {{item.roundName}}</text>
      </view>
      <view class="pc-footer" wx:if="{{item.lastScore !== null}}">
        <text class="pc-score" wx:if="{{role==='expert'}}">得分：{{item.lastScore}}</text>
        <text class="pc-score" wx:else>{{item.lastScore}}</text>
        <text class="pc-grade" wx:if="{{item.gradeLabel}}" style="color:{{item.gradeColor}}">{{item.gradeLabel}}</text>
      </view>
    </view>
  </block>

  <view wx:else class="empty-state">
    <text style="font-size:80rpx">📭</text>
    <text>{{filter==='all' ? '暂无项目' : '没有符合条件的项目'}}</text>
  </view>
</view>
