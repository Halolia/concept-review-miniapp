<!-- 评审结果汇总页 -->
<view class="container">
  <view wx:if="{{loading}}" class="empty-state">
    <text style="font-size:80rpx">⏳</text>
    <text>加载中…</text>
  </view>

  <block wx:else>
    <!-- 批次选择 -->
    <view class="card" wx:if="{{rounds.length > 0}}">
      <view class="section-title">查看批次</view>
      <picker range="{{rounds}}" range-key="name" bindchange="onRoundChange">
        <view class="picker-display">
          <text>{{rounds[0].name || '选择批次'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
      <view wx:if="{{summary.isClosed}}" class="tag tag-good" style="margin-top:12rpx">正式排名</view>
      <view wx:else class="tag tag-pending" style="margin-top:12rpx">评审未结束</view>
    </view>

    <!-- 总览 -->
    <view class="card overview">
      <view class="overview-title">评审概览</view>
      <view class="overview-stats">
        <view class="ov-item">
          <text class="ov-num">{{summary.totalProjects}}</text>
          <text class="ov-label">参评项目</text>
        </view>
        <view class="ov-item">
          <text class="ov-num">{{summary.totalReviews}}</text>
          <text class="ov-label">评审记录</text>
        </view>
        <view class="ov-item">
          <text class="ov-num done">{{summary.avgScore}}</text>
          <text class="ov-label">均分</text>
        </view>
      </view>
    </view>

    <!-- 排名列表 -->
    <view class="card ranking-card">
      <view class="ranking-title">📊 项目得分排名</view>

      <view class="rank-item" wx:for="{{rankings}}" wx:key="projectId"
            bindtap="goResult" data-id="{{item.projectId}}" data-name="{{item.projectName}}">
        <view class="rank-badge rank-{{item.rank}}">{{item.rank <= 3 ? ['🥇','🥈','🥉'][item.rank-1] : item.rank}}</view>
        <view class="rank-info">
          <text class="rank-name">{{item.projectName}}</text>
          <text class="rank-institution" wx:if="{{item.institution}}">{{item.institution}}</text>
        </view>
        <view class="rank-score-wrap">
          <text class="rank-score">{{item.avgScore}}</text>
          <view class="tag tag-{{item.gradeClass}}">{{item.gradeLabel}}</view>
        </view>
      </view>
    </view>
  </block>
</view>
