.container { padding-bottom: 40rpx; }

.overview {}
.overview-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}
.overview-stats { display: flex; justify-content: space-around; }
.ov-item { text-align: center; }
.ov-num { display: block; font-size: 44rpx; font-weight: 700; }
.ov-num.done { color: var(--primary); }
.ov-label { display: block; font-size: 22rpx; color: var(--text-secondary); margin-top: 6rpx; }

.ranking-card { padding-top: 20rpx; }
.ranking-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.rank-item:last-child { border-bottom: none; }
.rank-badge {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.rank-1 { background: #fff7e6; }
.rank-2 { background: #f5f5f5; }
.rank-3 { background: #fff3e0; }
.rank-info { flex: 1; min-width: 0; }
.rank-name {
  font-size: 26rpx;
  font-weight: 500;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.rank-institution {
  font-size: 22rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 4rpx;
}
.rank-score-wrap { text-align: right; flex-shrink: 0; margin-left: 16rpx; }
.rank-score { font-size: 32rpx; font-weight: 700; display: block; }
