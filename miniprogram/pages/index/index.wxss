.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.banner {
  background: linear-gradient(135deg, #1a6fb5 0%, #2196F3 100%);
  padding: 60rpx 40rpx;
  color: #fff;
}
.banner-title {
  font-size: 40rpx;
  font-weight: 700;
}
.banner-sub {
  font-size: 26rpx;
  opacity: 0.85;
  margin-top: 10rpx;
}

.role-switch {}
.role-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}
.role-btns {
  display: flex;
  gap: 16rpx;
}
.role-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: var(--radius);
  background: var(--bg);
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
  transition: all 0.2s;
}
.role-btn.active {
  background: var(--primary-light);
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

.picker-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: var(--bg);
  border-radius: var(--radius);
  font-size: 28rpx;
}
.picker-arrow {
  color: var(--text-secondary);
  font-size: 22rpx;
}

.stats {}
.stats-title {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
}
.stats-row {
  display: flex;
  justify-content: space-around;
}
.stat-item {
  text-align: center;
}
.stat-num {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
}
.stat-num.pending { color: var(--warning); }
.stat-num.done { color: var(--success); }
.stat-num.returned { color: #ff4d4f; }
.stat-num.warn { color: #ff976a; }
.stat-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.actions {}
.action-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
}
.action-item + .action-item {
  border-top: 1rpx solid var(--border);
}
.action-icon {
  font-size: 44rpx;
  width: 80rpx;
  text-align: center;
}
.action-text {
  flex: 1;
}
.action-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
}
.action-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}
.action-arrow {
  color: var(--text-secondary);
  font-size: 32rpx;
}
