.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.banner {
  background: linear-gradient(135deg, #1a6fb5 0%, #2196F3 100%);
  padding: 60rpx 40rpx;
  color: #fff;
}
.banner-title { font-size: 40rpx; font-weight: 700; }
.banner-sub { font-size: 26rpx; opacity: 0.85; margin-top: 10rpx; }

/* 未绑定 */
.guest-notice { text-align: center; padding: 48rpx 24rpx; }
.guest-text { display: block; font-size: 32rpx; font-weight: 600; margin-top: 20rpx; }
.guest-sub { display: block; font-size: 26rpx; color: var(--text-secondary); margin-top: 12rpx; }

/* 欢迎 */
.welcome-card { display: flex; align-items: center; }
.welcome-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; background: var(--primary-light); display: flex; align-items: center; justify-content: center; font-size: 36rpx; flex-shrink: 0; }
.welcome-info { margin-left: 20rpx; }
.welcome-name { font-size: 32rpx; font-weight: 600; display: block; }
.welcome-role { font-size: 24rpx; color: var(--text-secondary); }

/* 评审人信息条 */
.reviewer-bar { display: flex; align-items: center; padding: 28rpx 24rpx; }
.reviewer-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; background: var(--primary); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 700; flex-shrink: 0; }
.reviewer-info { flex: 1; margin-left: 16rpx; }
.reviewer-name { font-size: 28rpx; font-weight: 600; display: block; }
.reviewer-session { font-size: 22rpx; color: var(--text-secondary); display: block; margin-top: 4rpx; }
.progress-ring { text-align: center; flex-shrink: 0; padding: 8rpx 20rpx; background: var(--primary-light); border-radius: 12rpx; }
.progress-text { font-size: 32rpx; font-weight: 700; color: var(--primary); display: block; }
.progress-label { font-size: 20rpx; color: var(--primary); }

/* 项目列表 */
.section-title { font-size: 26rpx; color: var(--text-secondary); margin-bottom: 16rpx; }

.proj-item { display: flex; align-items: center; padding: 18rpx 0; border-bottom: 1rpx solid var(--border); }
.proj-item:last-child { border-bottom: none; }
.pj-left { margin-right: 16rpx; }
.pj-index { width: 40rpx; height: 40rpx; border-radius: 50%; background: var(--bg); display: flex; align-items: center; justify-content: center; font-size: 24rpx; color: var(--text-secondary); }
.pj-info { flex: 1; min-width: 0; }
.pj-name { font-size: 28rpx; font-weight: 500; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.pj-institution { font-size: 22rpx; color: var(--text-secondary); display: block; margin-top: 4rpx; }
.pj-right { display: flex; align-items: center; gap: 12rpx; flex-shrink: 0; margin-left: 12rpx; }
.action-arrow { color: var(--text-secondary); font-size: 28rpx; }

/* 会话列表 */
.session-item { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid var(--border); }
.session-item:last-child { border-bottom: none; }
.session-info { flex: 1; min-width: 0; }
.session-name { font-size: 28rpx; font-weight: 500; display: block; }
.session-date { font-size: 22rpx; color: var(--text-secondary); display: block; margin-top: 4rpx; }
.session-status { flex-shrink: 0; margin: 0 16rpx; }
.session-status-tag { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 4rpx; }
.session-status-tag.status-open { background: #e8f8ee; color: #07c160; }
.session-status-tag.status-closed { background: #f5f5f5; color: #999; }
.session-status-tag.status-draft { background: #fff3e0; color: #ff976a; }
.session-actions { display: flex; gap: 8rpx; flex-shrink: 0; }
.session-action-btn { font-size: 32rpx; padding: 4rpx; }

/* 操作入口 */
.actions {}
.action-item { display: flex; align-items: center; padding: 24rpx 0; }
.action-item + .action-item { border-top: 1rpx solid var(--border); }
.action-icon { font-size: 44rpx; width: 80rpx; text-align: center; }
.action-text { flex: 1; }
.action-title { display: block; font-size: 30rpx; font-weight: 500; }
.action-desc { display: block; font-size: 24rpx; color: var(--text-secondary); margin-top: 4rpx; }
