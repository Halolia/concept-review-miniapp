<!-- 首页 - 路演现场评分 -->
<view class="container">
  <!-- 顶部横幅 -->
  <view class="banner">
    <view class="banner-title">路演现场评分</view>
    <view class="banner-sub">扫码绑定 · 即时打分</view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="empty-state">
    <text style="font-size:80rpx">⏳</text>
    <text>加载中…</text>
  </view>

  <!-- 未绑定提示 -->
  <view wx:elif="{{role==='guest'}}" class="card guest-notice">
    <text style="font-size:60rpx;text-align:center;display:block">📱</text>
    <text class="guest-text">请扫描路演现场二维码</text>
    <text class="guest-sub">扫描二维码后自动识别您的评审身份，即可开始评分</text>
    <button class="btn btn-primary btn-block" style="margin:30rpx 0 0"
            bindscancode="onScanCode" open-type="scanCode">扫码绑定</button>
  </view>

  <!-- === 评审人视图 === -->
  <block wx:elif="{{role==='reviewer'}}">
    <!-- 评审人信息条 -->
    <view class="card reviewer-bar">
      <view class="reviewer-avatar">{{userName[0] || '👤'}}</view>
      <view class="reviewer-info">
        <text class="reviewer-name">{{userName}}</text>
        <text class="reviewer-session">{{sessionName || '路演评审'}}</text>
      </view>
      <view class="progress-ring">
        <text class="progress-text">{{progress.done}}/{{progress.total}}</text>
        <text class="progress-label">已完成</text>
      </view>
    </view>

    <!-- 项目列表 -->
    <view class="card" wx:if="{{projects.length > 0}}">
      <view class="section-title">评审项目（{{projects.length}}）</view>
      <view class="proj-item" wx:for="{{projects}}" wx:key="_id"
            bindtap="goReview" data-id="{{item._id}}" data-name="{{item.name}}">
        <view class="pj-left">
          <text class="pj-index">{{index + 1}}</text>
        </view>
        <view class="pj-info">
          <text class="pj-name">{{item.name}}</text>
          <text class="pj-institution" wx:if="{{item.institution}}">{{item.institution}}</text>
        </view>
        <view class="pj-right">
          <view class="tag {{item.statusClass}}">{{item.statusLabel}}</view>
          <text class="action-arrow">→</text>
        </view>
      </view>
    </view>

    <!-- 全部完成提示 -->
    <view class="card" wx:if="{{progress.done === progress.total && progress.total > 0}}" style="background:#e8f8ee">
      <view style="text-align:center">
        <text style="font-size:48rpx">🎉</text>
        <text style="display:block;font-size:28rpx;color:#07c160;margin-top:12rpx">所有项目已评分完毕</text>
      </view>
    </view>
  </block>

  <!-- === 管理员视图 === -->
  <block wx:elif="{{role==='admin'}}">
    <view class="card welcome-card">
      <view class="welcome-avatar">⚙️</view>
      <view class="welcome-info">
        <text class="welcome-name">{{userName}}</text>
        <text class="welcome-role">管理员</text>
      </view>
    </view>

    <!-- 会话列表 -->
    <view class="card" wx:if="{{sessions.length > 0}}">
      <view class="section-title">评审场次（{{sessions.length}}）</view>
      <view class="session-item" wx:for="{{sessions}}" wx:key="_id">
        <view class="session-info" bindtap="goSession" data-id="{{item._id}}">
          <text class="session-name">{{item.name}}</text>
          <text class="session-date" wx:if="{{item.date}}">{{item.date}}</text>
        </view>
        <view class="session-status">
          <text class="session-status-tag status-{{item.status}}">
            {{item.status === 'open' ? '进行中' : item.status === 'closed' ? '已结束' : '草稿'}}
          </text>
        </view>
        <view class="session-actions">
          <text class="session-action-btn" bindtap="goProgress" data-id="{{item._id}}">📊</text>
          <text class="session-action-btn" bindtap="goSession" data-id="{{item._id}}">⚙️</text>
        </view>
      </view>
    </view>

    <!-- 创建会话入口 -->
    <view class="card actions">
      <view class="action-item" bindtap="goCreateSession">
        <view class="action-icon">➕</view>
        <view class="action-text">
          <text class="action-title">创建评审场次</text>
          <text class="action-desc">新增路演评审活动</text>
        </view>
        <text class="action-arrow">→</text>
      </view>
    </view>
  </block>
</view>
