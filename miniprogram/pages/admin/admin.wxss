.container { padding-bottom: 40rpx; }

.tab-bar {
  display: flex;
  background: #fff;
  margin-bottom: 20rpx;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-bottom: 4rpx solid transparent;
}
.tab-item.active {
  color: var(--primary);
  border-bottom-color: var(--primary);
  font-weight: 500;
}

.add-card {}
.add-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.add-input {
  width: 100%;
  padding: 18rpx 16rpx;
  background: var(--bg);
  border-radius: 8rpx;
  font-size: 26rpx;
  margin-bottom: 12rpx;
  box-sizing: border-box;
}

.proj-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.proj-item:last-child { border-bottom: none; }
.pj-info { flex: 1; min-width: 0; }
.pj-name { font-size: 26rpx; font-weight: 500; display: block; }
.pj-institution { font-size: 22rpx; color: var(--text-secondary); margin-top: 4rpx; display: block; }
.pj-del { font-size: 24rpx; color: var(--danger); flex-shrink: 0; margin-left: 16rpx; }

.assign-proj-name {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.assign-label { font-size: 24rpx; color: var(--text-secondary); }
.assign-tags { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 12rpx; }
.assign-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: var(--primary-light);
  color: var(--primary);
  border-radius: 6rpx;
  font-size: 24rpx;
}
.assign-remove {
  margin-left: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--danger);
  line-height: 1;
}
.assign-add-btn {
  display: inline-block;
  margin-top: 16rpx;
  padding: 10rpx 24rpx;
  border: 2rpx dashed var(--primary);
  border-radius: 8rpx;
  color: var(--primary);
  font-size: 24rpx;
}

.reviewer-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
  font-size: 28rpx;
}
.reviewer-item:last-child { border-bottom: none; }
