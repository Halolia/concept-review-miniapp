/* 评分页 v1.1 - 路演现场评分 */

/* 页面根容器 */
page { height: 100%; }

.review-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #f5f6fa;
}

/* 顶部固定 */
.review-header {
  flex-shrink: 0;
  background: linear-gradient(135deg, #1a6fb5, #2196F3);
  padding: 20rpx 32rpx;
  color: #fff;
}
.rh-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  line-height: 1.3;
  margin-bottom: 8rpx;
}
.rh-score {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}
.rh-total {
  font-size: 52rpx;
  font-weight: 700;
}
.rh-unit {
  font-size: 24rpx;
  opacity: 0.8;
}
.rh-grade {
  font-size: 30rpx;
  font-weight: bold;
  margin-left: 12rpx;
}

.locked-banner {
  flex-shrink: 0;
  text-align: center;
  padding: 14rpx 32rpx;
  background: #fff3e0;
  color: #e65100;
  font-size: 26rpx;
}

/* 中间滚动区域 —— 关键修复 */
.review-scroll {
  flex: 1;
  min-height: 0;
  width: 100%;
  box-sizing: border-box;
  padding: 16rpx 20rpx 0;
}

/* 评分维度 */
.dim-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
}
.dim-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #eee;
}
.dim-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a6fb5;
}
.dim-weight {
  font-size: 22rpx;
  color: #999;
}

.item-row { margin-bottom: 16rpx; }
.item-label-wrap {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.item-label { font-size: 26rpx; color: #333; }
.item-max { font-size: 22rpx; color: #bbb; }
.item-score-input {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.stepper {
  display: flex;
  align-items: center;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  overflow: hidden;
}
.stepper-btn {
  width: 64rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
  background: #f5f5f5; font-size: 32rpx; color: #333;
}
.stepper-btn.disabled { color: #ccc; background: #fafafa; }
.stepper-value {
  width: 80rpx; height: 56rpx;
  text-align: center; font-size: 28rpx; font-weight: bold;
  border-left: 1rpx solid #ddd; border-right: 1rpx solid #ddd;
}
.item-max-hint { font-size: 22rpx; color: #bbb; }

.score-bar-mini {
  height: 6rpx; background: #eee; border-radius: 3rpx; margin-top: 6rpx;
}
.score-bar-mini-fill {
  height: 100%; border-radius: 3rpx; transition: width 0.2s;
}

/* 表单卡片 */
.form-card {
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 28rpx; font-weight: bold; color: #333; margin-bottom: 16rpx;
}
.name-input {
  padding: 16rpx 20rpx; background: #f8f8f8; border-radius: 8rpx;
  font-size: 28rpx; border: 1rpx solid #eee;
}
.comment-input {
  width: 100%; min-height: 120rpx;
  padding: 16rpx 20rpx; background: #f8f8f8; border-radius: 8rpx;
  font-size: 28rpx; box-sizing: border-box; border: 1rpx solid #eee;
}

/* 评审人信息 */
.reviewer-info {
  padding: 16rpx 0;
}
.reviewer-name {
  display: block; font-size: 30rpx; font-weight: bold; color: #333;
}
.reviewer-hint {
  display: block; font-size: 24rpx; color: #999; margin-top: 8rpx;
}

/* 确认勾选 */
.confirm-card { background: #f0f7ff; border: 1rpx solid #b3d9ff; }
.confirm-label {
  display: flex; align-items: center; gap: 12rpx;
}
.confirm-text {
  font-size: 28rpx; color: #1a6fb5; font-weight: 500;
}

/* 底部操作栏 */
.action-bar {
  flex-shrink: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.06);
}
.action-btn-left {
  flex: 1; height: 80rpx; line-height: 80rpx;
  font-size: 30rpx; border-radius: 12rpx;
}
.action-btn-right {
  flex: 1; height: 80rpx; line-height: 80rpx;
  font-size: 30rpx; border-radius: 12rpx;
  background: #1a6fb5; color: #fff;
}

.locked-bar {
  flex-shrink: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  text-align: center;
}
.locked-notice {
  font-size: 26rpx; color: #999;
}

/* 按钮样式 */
.btn { text-align: center; border-radius: 12rpx; }
.btn-outline { background: #fff; border: 2rpx solid #1a6fb5; color: #1a6fb5; }
.btn-primary { background: #1a6fb5; color: #fff; }

/* 卡片 */
.card { background: #fff; border-radius: 12rpx; padding: 24rpx 20rpx; }
