.container { padding-bottom: 40rpx; }

/* 项目头部 */
.proj-header {
  background: linear-gradient(135deg, #1a6fb5, #2196F3);
  color: #fff;
  padding: 36rpx 30rpx;
}
.proj-name {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.4;
}
.proj-meta {
  display: flex;
  gap: 24rpx;
  margin-top: 12rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

/* 悬浮分数条 */
.score-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  margin: -16rpx 20rpx 20rpx;
  padding: 24rpx 30rpx;
  border-radius: var(--radius);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  position: sticky;
  top: 0;
  z-index: 10;
}
.score-bar-left { display: flex; align-items: baseline; }
.score-bar-total { font-size: 48rpx; font-weight: 800; color: var(--text); line-height: 1; }
.score-bar-unit { font-size: 24rpx; color: var(--text-secondary); margin-left: 8rpx; }
.score-bar-grade { font-size: 32rpx; font-weight: 700; }

/* 评分维度 */
.dim-section {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.dim-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--primary-light);
  border-bottom: 1rpx solid #d4e8f8;
}
.dim-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}
.dim-weight {
  font-size: 24rpx;
  color: var(--primary);
  opacity: 0.7;
}

/* 子项行 */
.item-row {
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
}
.item-row:last-child { border-bottom: none; }
.item-label-wrap {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.item-label {
  font-size: 26rpx;
  color: var(--text);
  line-height: 1.5;
}
.item-max {
  font-size: 22rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 步进器 */
.item-score-input {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.stepper {
  display: flex;
  align-items: center;
  border: 2rpx solid var(--border);
  border-radius: 8rpx;
  overflow: hidden;
}
.stepper-btn {
  width: 64rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 300;
  color: var(--primary);
  background: var(--bg);
  user-select: none;
}
.stepper-btn:active { background: #d4e8f8; }
.stepper-btn.disabled { color: #ccc; }
.stepper-value {
  width: 80rpx;
  height: 56rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  border-left: 2rpx solid var(--border);
  border-right: 2rpx solid var(--border);
  background: #fff;
}
.item-max-hint {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 迷你进度条 */
.score-bar-mini {
  height: 6rpx;
  background: #f0f0f0;
  border-radius: 3rpx;
  margin-top: 12rpx;
  overflow: hidden;
}
.score-bar-mini-fill {
  height: 100%;
  border-radius: 3rpx;
  transition: width 0.2s ease, background 0.2s ease;
  min-width: 4rpx;
}

/* 意见输入 */
.comment-section { margin-top: 0; }
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}
.section-hint {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}
.comment-input {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx;
  background: var(--bg);
  border-radius: 8rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

/* 签名区 */
.sign-section { margin-top: 0; }
.name-input {
  width: 100%;
  padding: 20rpx 16rpx;
  background: var(--bg);
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-top: 12rpx;
}

/* 提交 */
.submit-area { margin-top: 20rpx; }
.submit-btn { 
  height: 88rpx; 
  font-size: 32rpx;
  letter-spacing: 4rpx;
}
.submit-btn[disabled] { background: #ccc; }
