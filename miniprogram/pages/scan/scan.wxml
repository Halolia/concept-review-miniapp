<!-- 扫码绑定页 -->
<view class="container">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="empty-state">
    <text style="font-size:80rpx">⏳</text>
    <text>正在查找邀请信息…</text>
  </view>

  <!-- 错误 -->
  <view wx:elif="{{error}}" class="card" style="text-align:center">
    <text style="font-size:60rpx;display:block">❌</text>
    <text class="error-text">{{error}}</text>
    <button class="btn btn-primary btn-block" style="margin-top:30rpx" bindtap="goBack">返回首页</button>
  </view>

  <!-- 邀请信息 -->
  <view wx:elif="{{inviteInfo}}">
    <view class="banner">
      <view class="banner-title">路演现场评分</view>
      <view class="banner-sub">扫码绑定评审身份</view>
    </view>

    <view class="card info-card">
      <!-- 已绑定提示 -->
      <view wx:if="{{inviteInfo.isBound}}" class="bound-notice">
        <text style="font-size:60rpx;display:block;text-align:center">✅</text>
        <text class="bound-text">该账号已绑定</text>
        <text class="bound-sub">无需重复绑定，可直接开始评分</text>
      </view>

      <!-- 未绑定：确认绑定 -->
      <block wx:else>
        <view class="info-item">
          <text class="info-label">场次名称</text>
          <text class="info-value">{{inviteInfo.sessionName || '--'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">评委姓名</text>
          <text class="info-value">{{inviteInfo.reviewerName || '--'}}</text>
        </view>
        <view class="info-item" wx:if="{{inviteInfo.organization}}">
          <text class="info-label">单位</text>
          <text class="info-value">{{inviteInfo.organization}}</text>
        </view>

        <view class="confirm-area">
          <text class="confirm-text">确认以上信息无误后，点击绑定开始评分</text>
          <button class="btn btn-primary btn-block" bindtap="confirmBind" disabled="{{binding}}">
            {{binding ? '绑定中…' : '确认绑定'}}
          </button>
          <button class="btn btn-outline btn-block" style="margin-top:16rpx" bindtap="goBack">取消</button>
        </view>
      </block>
    </view>

    <!-- 已绑定：去评分 -->
    <view wx:if="{{inviteInfo.isBound}}" class="card" style="text-align:center">
      <button class="btn btn-primary btn-block" bindtap="goBack">进入评分</button>
    </view>
  </view>
</view>
