.container { min-height: 100vh; padding-bottom: 40rpx; }

.banner {
  background: linear-gradient(135deg, #1a6fb5 0%, #2196F3 100%);
  padding: 60rpx 40rpx;
  color: #fff;
}
.banner-title { font-size: 40rpx; font-weight: 700; }
.banner-sub { font-size: 26rpx; opacity: 0.85; margin-top: 10rpx; }

/* 错误 */
.error-text { display: block; font-size: 28rpx; color: var(--danger); margin-top: 16rpx; }

/* 邀请信息卡片 */
.info-card { padding: 32rpx; }
.info-item { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid var(--border); }
.info-item:last-child { border-bottom: none; }
.info-label { font-size: 26rpx; color: var(--text-secondary); }
.info-value { font-size: 28rpx; font-weight: 500; color: var(--text); }

/* 已绑定 */
.bound-notice { padding: 20rpx 0; }
.bound-text { display: block; font-size: 32rpx; font-weight: 600; color: #07c160; text-align: center; margin-top: 12rpx; }
.bound-sub { display: block; font-size: 24rpx; color: var(--text-secondary); text-align: center; margin-top: 8rpx; }

/* 确认区域 */
.confirm-area { margin-top: 32rpx; text-align: center; }
.confirm-text { font-size: 24rpx; color: var(--text-secondary); display: block; margin-bottom: 20rpx; }
