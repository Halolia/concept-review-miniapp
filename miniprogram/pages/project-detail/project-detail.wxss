.proj-header {
  padding: 30rpx 32rpx;
  background: linear-gradient(135deg, #1a6fb5 0%, #2196F3 100%);
  color: #fff;
}
.ph-name {
  font-size: 36rpx;
  font-weight: bold;
  line-height: 1.4;
  display: block;
}
.ph-meta {
  display: flex;
  gap: 20rpx;
  margin-top: 12rpx;
  font-size: 26rpx;
  opacity: 0.9;
}

.info-card { margin-top: 20rpx; }
.info-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}
.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx;
}
.info-label { color: #888; }
.info-value { color: #333; font-weight: 500; }

.tag-round-open { color: #07c160; font-weight: bold; }
.tag-round-closed { color: #ee0a24; font-weight: bold; }
.tag-round-draft { color: #999; }

.status-card { margin-top: 20rpx; }
.status-badge {
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
}
.status-assigned { background: #fff3e0; color: #e65100; }
.status-draft { background: #e8f5e9; color: #2e7d32; }
.status-submitted { background: #e3f2fd; color: #1565c0; }
.status-resubmitted { background: #e3f2fd; color: #1565c0; }
.status-returned { background: #fce4ec; color: #c62828; }
.status-locked { background: #f5f5f5; color: #999; }

.status-hint {
  display: block;
  text-align: center;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #c62828;
}

.materials-card { margin-top: 20rpx; }
.materials-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}
.materials-hint { font-size: 28rpx; color: #999; margin-top: 16rpx; }
.materials-sub-hint { font-size: 24rpx; color: #ccc; margin-top: 8rpx; }

.notice-card { margin-top: 20rpx; background: #fffbe6; border: 1rpx solid #ffe58f; }
.notice-title { font-size: 28rpx; font-weight: bold; color: #ad6800; margin-bottom: 12rpx; }
.notice-text { font-size: 26rpx; color: #8c6a00; line-height: 1.6; }

.action-area { margin-top: 30rpx; padding: 0 32rpx; }
