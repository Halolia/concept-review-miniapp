/* 全局样式 */
page {
  --primary: #1a6fb5;
  --primary-light: #e8f4fd;
  --success: #07c160;
  --warning: #ff976a;
  --danger: #ee0a24;
  --info: #1989fa;
  --bg: #f5f6fa;
  --card-bg: #ffffff;
  --text: #323233;
  --text-secondary: #969799;
  --border: #ebedf0;
  --radius: 12rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: var(--text);
  background: var(--bg);
  line-height: 1.6;
}

/* 通用卡片 */
.card {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 24rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

/* 通用按钮 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 40rpx;
  border-radius: var(--radius);
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.btn-primary {
  background: var(--primary);
  color: #fff;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-success {
  background: var(--success);
  color: #fff;
}

.btn-outline {
  background: #fff;
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

.btn-block {
  display: flex;
  width: calc(100% - 40rpx);
  margin: 20rpx;
}

.btn-small {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
}

/* 通用标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-excellent { background: #e6f9ef; color: #07c160; }
.tag-good { background: #e8f4fd; color: #1989fa; }
.tag-normal { background: #fff3e8; color: #ff976a; }
.tag-fail { background: #fde8ec; color: #ee0a24; }
.tag-pending { background: #f5f5f5; color: #969799; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: var(--text-secondary);
}
.empty-state text {
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 20rpx 0;
}
